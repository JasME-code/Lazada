<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- =====================================================
         APP BAR — collapses on scroll (UNCHANGED)
         ===================================================== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:liftOnScroll="true"
        app:liftOnScrollColor="#F57224"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_scrollFlags="scroll|enterAlways|snap"
            app:titleEnabled="false">

            <!-- Promo Strip + Full Header (UNCHANGED) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_collapseMode="parallax">

                <!-- [YOUR EXISTING PROMO STRIP] -->
        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_scrollFlags="scroll|enterAlways|snap"
            app:titleEnabled="false">

            <!-- Promo Strip + Full Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_collapseMode="parallax">

                <!-- Promo Strip -->
                <LinearLayout
                    android:id="@+id/promoStrip"
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:background="#FFFFFF"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp">
                    <!-- [KEEP ALL 4 TEXTVIEWS] -->
                </LinearLayout>

                <!-- Header Full -->
                <LinearLayout
                    android:id="@+id/headerFull"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/lazada_gradient_header"
                    android:orientation="vertical"
                    android:padding="10dp">
                    <!-- [KEEP ALL SEARCH + LOGO] -->
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.appbar.CollapsingToolbarLayout>

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/compactToolbar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/lazada_gradient_header"
            android:paddingHorizontal="10dp"
            app:layout_scrollFlags="noScroll" />


    </com.google.android.material.appbar.AppBarLayout>

    <!-- SCROLLABLE CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="60dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== QUICK LINKS (IMPROVED) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:gravity="center">

                <!-- Top Up -->
                <LinearLayout
                    android:id="@+id/btnTopUp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_topup"
                        android:contentDescription="Top Up" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Top Up"
                        android:textSize="12sp"
                        android:textColor="#1A1A1A"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- LazMall -->
                <LinearLayout
                    android:id="@+id/btnLazMall"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_lazmall"
                        android:contentDescription="LazMall" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LazMall"
                        android:textSize="12sp"
                        android:textColor="#1A1A1A"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Vouchers -->
                <LinearLayout
                    android:id="@+id/btnVouchers"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_voucher"
                        android:contentDescription="Vouchers" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vouchers"
                        android:textSize="12sp"
                        android:textColor="#1A1A1A"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Wallet -->
                <LinearLayout
                    android:id="@+id/btnWallet"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_wallet"
                        android:contentDescription="Wallet" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wallet"
                        android:textSize="12sp"
                        android:textColor="#1A1A1A"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

            </LinearLayout>


            <!-- ===== FLASH SALE (UNCHANGED HEADER + HORIZONTAL SCROLL) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:layout_marginTop="8dp"
                android:paddingTop="12dp">

                <!-- FLASH SALE HEADER + TIMER (UNCHANGED) -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="12dp" android:layout_marginBottom="10dp">
                    <!-- [KEEP TIMER + SHOP ALL] -->
                </LinearLayout>

                <!-- HORIZONTAL SCROLL PRODUCTS (UNCHANGED) -->
                <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:scrollbars="none" android:paddingHorizontal="12dp" android:paddingBottom="12dp" android:clipToPadding="false">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                        <!-- [KEEP 3 PRODUCT CARDS] -->
                    </LinearLayout>
                </HorizontalScrollView>

            </LinearLayout>

            <!-- 🔥🔥 NEW FLASH SALE LISTVIEW SECTION 🔥🔥 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="#FFFFFF"
                android:orientation="vertical">

                <!-- NEW Flash Sale List Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🛒 MORE FLASH SALE ITEMS"
                        android:textColor="#1A1A1A"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvViewAllFlashSale"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VIEW ALL >"
                        android:textColor="#F57224"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- NEW ListView (scrollable products) -->
                <ListView
                    android:id="@+id/listViewFlashSale"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="0dp"
                    android:scrollbars="none"
                    android:paddingHorizontal="12dp"
                    android:paddingBottom="12dp" />

            </LinearLayout>
            <!-- 🔥 END NEW LISTVIEW SECTION 🔥 -->

            <!-- ===== SHOP BY CATEGORY (UNCHANGED) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:layout_marginTop="8dp"
                android:padding="12dp">

                <!-- [KEEP ALL CATEGORY GRID] -->
                <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:columnCount="4" android:rowCount="2">
                    <!-- Gaming, Adult, Kids, Toys, etc. -->
                </GridLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="16dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ===== BOTTOM NAVIGATION (UNCHANGED) ===== -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp" android:layout_gravity="bottom" android:background="#FFFFFF" android:orientation="horizontal" android:elevation="8dp">
        <!-- [KEEP ALL 5 BOTTOM NAV ITEMS] -->
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>